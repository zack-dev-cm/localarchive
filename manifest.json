{
  "manifest_version": 3,
  "name": "LocalArchive",
  "version": "0.1.0",
  "description": "Local-first page archive with Pocket import and portable exports.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["activeTab", "contextMenus", "downloads", "scripting", "sidePanel", "storage"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LocalArchive",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/library.html"
  }
}
